generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model alternativas {
  id      Int      @id @default(autoincrement())
  texto   String   @db.Text
  correta Boolean? @default(false)

  pergunta_id Int?

  perguntas perguntas? @relation(fields: [pergunta_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "alternativas_ibfk_1")

  @@index([pergunta_id], map: "pergunta_id")
}

model perguntas {
  id    Int    @id @default(autoincrement())
  texto String @db.Text

  quiz_id Int?

  quizzes quizzes? @relation(fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "perguntas_ibfk_1")

  alternativas alternativas[]

  @@index([quiz_id], map: "quiz_id")
}

model quizzes {
  id          Int                  @id @default(autoincrement())
  titulo      String               @db.VarChar(100)
  descricao   String?              @db.Text
  dificuldade quizzes_dificuldade?

  usuario_id Int?
  tema_id    Int?

  perguntas perguntas[]

  usuarios usuarios? @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "quizzes_ibfk_1")

  temas      temas?       @relation(fields: [tema_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "quizzes_ibfk_2")
  tentativas tentativas[]

  @@index([tema_id], map: "tema_id")
  @@index([usuario_id], map: "usuario_id")
}

model tentativas {
  id Int @id @default(autoincrement())

  usuario_id Int
  quiz_id    Int

  pontuacao      Int
  total_questoes Int

  tempo_segundos     Int
  tempo_milisegundos Int @default(0)

  created_at DateTime @default(now())

  usuarios usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  quizzes quizzes @relation(fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuario_id])
  @@index([quiz_id])
}

model temas {
  id   Int    @id @default(autoincrement())
  nome String @db.VarChar(100)

  quizzes quizzes[]
}

model usuarios {
  id            Int    @id @default(autoincrement())
  username      String @unique(map: "username") @db.VarChar(50)
  nome_completo String @db.VarChar(100)
  email         String @unique(map: "email") @db.VarChar(100)
  senha         String @db.VarChar(255)

  quizzes    quizzes[]
  tentativas tentativas[]
}

enum quizzes_dificuldade {
  facil
  medio
  intermediario
  dificil
}
